generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id        String   @id @default(uuid())
  ref       String   @db.VarChar(255)
  customer  String   @db.VarChar(255)
  pickup    String   @db.VarChar(255)
  dropoff   String   @db.VarChar(255)
  warehouse String?  @db.VarChar(255)

  priority  String   @db.VarChar(50)
  status    String   @db.VarChar(50)
  jobType     String   @default("order") @db.VarChar(50)
  serviceType      String?  @db.VarChar(50)   // "delivery" or "collection"
  transportService String?  @db.VarChar(50)   // "express", "economy", "outline"
  truckSize        String?  @db.VarChar(50)   // "1ton", "4ton", "8ton", "6m", "12m", "superlink"
  etd              String?  @db.VarChar(255)  // Estimated Time of Departure

  pallets          Int?
  outstandingQty   Int?

  eta                String?   @db.VarChar(255)
  scheduledAt        String?   @db.VarChar(255)
  dispatchedAt       String?   @db.VarChar(255)
  actualDeliveryAt   String?   @db.VarChar(255)
  returnedAt         String?   @db.VarChar(255)
  returnReason       String?   @db.Text
  returnedPallets    Int?
  returnNotes        String?   @db.Text
  exceptionReason    String?   @db.Text
  overdueReason      String?   @db.Text

  transporterBooked  Boolean?  @default(false)
  orderPicked        Boolean?  @default(false)
  coaAvailable       Boolean?  @default(false)
  hasFlowbin         Boolean?  @default(false)

  driverId  String?  @db.VarChar(255)
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  notes          String?  @db.Text
  internalNotes  String?  @db.Text

  createdById String?  @db.VarChar(255)

  flowbinBatches FlowbinBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([driverId])
  @@index([warehouse])
  @@index([jobType])
  @@index([ref])
  @@index([createdAt])
  @@index([eta])
  @@index([createdById])
  @@map("jobs")
}

model Driver {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(255)
  callsign     String   @unique @db.VarChar(50)
  location     String   @db.VarChar(255)
  capacity     Int
  assignedJobs Int      @default(0)
  status       String   @db.VarChar(50)
  phone        String?  @db.VarChar(50)
  email        String?  @db.VarChar(255)

  jobs         Job[]

  @@index([status])
  @@index([name])
  @@map("drivers")
}

model AfricaExportShipment {
  id                    String   @id @default(uuid())
  ref                   String   @unique @db.VarChar(255)
  customer              String   @db.VarChar(255)
  destinationCountry    String?  @db.VarChar(255)
  hsCode                String?  @db.VarChar(500)
  productType           String?  @db.Text
  incoterm              String   @default("FCA") @db.VarChar(50)
  transportMode         String   @default("Road") @db.VarChar(50)
  preferenceScheme      String   @default("To confirm") @db.VarChar(100)
  destinationAgent      String?  @db.Text
  eta                   String?  @db.VarChar(255)
  quantity              Float    @default(0)
  pallets               Int      @default(0)
  status                String   @default("pending") @db.VarChar(50)
  assignedTransporterId String?  @db.VarChar(255)
  assignedTransporter   AfricaExportTransporter? @relation(fields: [assignedTransporterId], references: [id], onDelete: SetNull)
  lastCheckedAt         String?  @db.VarChar(255)
  notes                 String?  @db.Text
  documents             Json     @default("{}")
  documentDetails       Json     @default("{}")
  history               Json     @default("[]")
  archived              Boolean  @default(false)
  dispatchApprovedAt    String?  @db.VarChar(255)
  dispatchApprovedBy    String?  @db.VarChar(255)
  createdById           String?  @db.VarChar(255)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([archived])
  @@index([destinationCountry])
  @@index([assignedTransporterId])
  @@index([eta])
  @@index([createdAt])
  @@map("africa_export_shipments")
}

model AfricaExportCountryRule {
  id                  String   @id @default(uuid())
  country             String   @unique @db.VarChar(255)
  title               String   @db.VarChar(255)
  points              Json     @default("[]")
  requiredDocumentIds Json     @default("[]")
  history             Json     @default("[]")
  updatedBy           String?  @db.VarChar(255)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([country])
  @@map("africa_export_country_rules")
}

model AfricaExportTransporter {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  route     String?  @db.VarChar(255)
  contact   String?  @db.Text
  capacity  Int      @default(0)
  status    String   @default("available") @db.VarChar(50)
  shipments AfricaExportShipment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([name])
  @@map("africa_export_transporters")
}

model User {
  id                   String    @id @default(uuid())
  username             String    @unique @db.VarChar(255)
  email                String    @unique @db.VarChar(255)
  password             String    @db.VarChar(255)
  role                 String    @default("user") @db.VarChar(50)
  passwordResetToken   String?   @db.VarChar(255)
  passwordResetExpires DateTime?
  lastSeenAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("users")
}

model Message {
  id          String   @id @default(uuid())
  senderId    String   @db.VarChar(255)
  senderName  String   @db.VarChar(255)
  subject     String   @db.VarChar(255)
  body        String   @db.Text
  jobRef      String?  @db.VarChar(255)  // optional link to an order
  priority    String   @default("normal") @db.VarChar(50)  // "normal" or "urgent"
  broadcast   Boolean  @default(false)  // sent to all users
  threadId    String?  @db.VarChar(255)  // links replies to original message
  recipients  MessageRecipient[]
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([jobRef])
  @@index([threadId])
  @@index([createdAt])
  @@map("messages")
}

model MessageRecipient {
  id         String   @id @default(uuid())
  messageId  String   @db.VarChar(255)
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId     String   @db.VarChar(255)
  username   String   @db.VarChar(255)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
  @@map("message_recipients")
}

model FlowbinBatch {
  id           String    @id @default(uuid())
  jobId        String    @db.VarChar(255)
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  batchNumber       String    @db.VarChar(255)
  quantity          Int
  quantityReturned  Int?
  returnedAt        DateTime?
  returnNotes       String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([jobId])
  @@map("flowbin_batches")
}

model InvoiceReconciliationLine {
  id              String   @id @default(uuid())
  rowKey          String   @unique @db.VarChar(500)
  aso             String   @db.VarChar(255)
  invoiceNumber   String?  @db.VarChar(255)
  invoiceDate     String?  @db.VarChar(50)
  deliveryDueDate String?  @db.VarChar(50)
  customer        String?  @db.VarChar(1000)
  invoiceQty      Float    @default(0)
  hasInvoiceQty   Boolean  @default(false)
  invoiceValue    Float?
  product         String?  @db.Text
  createdBy       String?  @db.VarChar(255)
  deliveryStatus  String?  @db.VarChar(255)
  status          String?  @db.VarChar(255)
  postedDate      String?  @db.VarChar(50)
  createdById     String?  @db.VarChar(255)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([aso])
  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([deliveryDueDate])
  @@index([createdAt])
  @@map("invoice_reconciliation_lines")
}

model InvoiceReconciliationReview {
  id          String   @id @default(uuid())
  aso         String   @unique @db.VarChar(255)
  status      String   @db.VarChar(100)
  updatedById String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
  @@map("invoice_reconciliation_reviews")
}

model InvoiceReconciliationTimingNote {
  id            String   @id @default(uuid())
  invoiceKey    String   @unique @db.VarChar(500)
  invoiceNumber String?  @db.VarChar(255)
  note          String   @db.Text
  updatedById   String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([invoiceNumber])
  @@index([updatedAt])
  @@map("invoice_reconciliation_timing_notes")
}

model InvoiceReconciliationUpload {
  id          String   @id @default(uuid())
  filename    String   @db.VarChar(1000)
  uploadedAt  DateTime @default(now())
  rowsAdded   Int      @default(0)
  rowsSkipped Int      @default(0)
  updatedById String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  @@index([uploadedAt])
  @@map("invoice_reconciliation_uploads")
}

model InvoiceReconciliationAudit {
  id         String   @id @default(uuid())
  entityType String   @db.VarChar(100)
  entityKey  String   @db.VarChar(500)
  action     String   @db.VarChar(255)
  fromValue  String?  @db.Text
  toValue    String?  @db.Text
  userId     String?  @db.VarChar(255)
  createdAt  DateTime @default(now())

  @@index([entityType, entityKey])
  @@index([createdAt])
  @@map("invoice_reconciliation_audits")
}
